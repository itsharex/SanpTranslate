{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri/feat/v2/core/tauri-config-schema/schema.json",
  "productName": "SnapTranslate",
  "version": "1.2.5",
  "identifier": "snaptranslate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:51896",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SnapTranslate",
        "width": 800,
        "height": 600,
        "visible": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "template": "nsis/installer.nsi",
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4ODUxN0E1OEU2MERERDAKUldUUTNXQ09wUmVGcUdPWURITlM0d0xhcGtTa0x2NEM5eVJkdmEvNXhYODVnZ25RZzA1eFI1T3QK",
      "endpoints": [
        "https://github.com/XuMingKe-06/SanpTranslate/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
